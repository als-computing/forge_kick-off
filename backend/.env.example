# Tiled server configuration
# Default server: Local Tiled at port 8010 (no API key required for open servers)
TILED_URI=http://127.0.0.1:8010
TILED_API_KEY=

# To authenticate with a local Tiled server, use:
# TILED_LOCAL_API_KEY=your-api-key-here

# To configure multiple named Tiled servers shown in the Browse dropdown:
# TILED_SERVER_1_NAME=My Remote Server
# TILED_SERVER_1_URI=https://tiled.example.com
# TILED_SERVER_1_API_KEY=secret-key-here
# TILED_SERVER_2_NAME=Another Server
# TILED_SERVER_2_URI=http://192.168.1.100:8010
# TILED_SERVER_2_API_KEY=

# Browse API cache TTL in seconds (default: 300 = 5 minutes)
BROWSE_CACHE_TTL_SECONDS=300
